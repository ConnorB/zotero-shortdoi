# Path to the Zotero binary. On macOS this is usually:
# /Applications/Zotero.app/Contents/MacOS/zotero
ZOTERO_PLUGIN_ZOTERO_BIN_PATH=/path/to/zotero

# Optional: use a dedicated development profile.
ZOTERO_PLUGIN_PROFILE_PATH=/path/to/zotero/profile

# Optional: use a dedicated development data directory.
# ZOTERO_PLUGIN_DATA_DIR=/path/to/zotero/data
